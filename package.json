{
  "name": "iobroker.hassemu",
  "version": "1.1.3",
  "description": "Emulates a minimal Home Assistant server so devices expecting a Home Assistant dashboard can display any custom web URL.",
  "author": {
    "name": "krobi",
    "email": "krobi@power-dreams.com"
  },
  "contributors": [
    {
      "name": "Claude (Anthropic)",
      "role": "Coding assistance"
    }
  ],
  "homepage": "https://github.com/krobipd/ioBroker.hassemu",
  "license": "MIT",
  "keywords": [
    "ioBroker",
    "homeassistant",
    "hass",
    "emulator",
    "dashboard",
    "redirect",
    "vis"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/krobipd/ioBroker.hassemu"
  },
  "bugs": {
    "url": "https://github.com/krobipd/ioBroker.hassemu/issues"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@iobroker/adapter-core": "^3.3.2",
    "bonjour-service": "^1.3.0",
    "fastify": "^5.8.5"
  },
  "devDependencies": {
    "@alcalzone/release-script": "^5.1.1",
    "@alcalzone/release-script-plugin-iobroker": "^5.1.2",
    "@alcalzone/release-script-plugin-license": "^5.1.1",
    "@alcalzone/release-script-plugin-manual-review": "^5.1.1",
    "@iobroker/adapter-dev": "^1.5.0",
    "@iobroker/eslint-config": "^2.2.0",
    "@iobroker/testing": "^5.2.2",
    "@tsconfig/node20": "^20.1.9",
    "@types/iobroker": "npm:@iobroker/types@^7.1.0",
    "@types/node": "^25.5.0",
    "rimraf": "^6.1.3",
    "typescript": "~5.9.3"
  },
  "main": "build/main.js",
  "files": [
    "admin/",
    "build/",
    "io-package.json",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "rimraf build",
    "build": "build-adapter ts",
    "watch": "build-adapter ts --watch",
    "check": "tsc --noEmit",
    "test:ts": "npm run build:test && mocha --exit \"build/test/test*.js\"",
    "test:package": "mocha test/package --exit",
    "test:integration": "mocha test/integration --exit",
    "test": "npm run build && npm run test:ts && npm run test:package",
    "build:test": "tsc -p tsconfig.test.json",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "translate": "translate-adapter",
    "release": "release-script"
  }
}
